{
  "address": "6sGQwrJHRr6N3Gvt1ouS4kEP8zSjB5RckhgRr12ftgTj",
  "metadata": {
    "name": "dead_mans_switch",
    "version": "0.1.0",
    "spec": "0.1.0"
  },
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        { "name": "switch",         "writable": true,  "pda": { "seeds": [{ "kind": "const", "value": [115,119,105,116,99,104] }, { "kind": "account", "path": "owner" }] } },
        { "name": "owner",          "writable": true,  "signer": true },
        { "name": "system_program", "address": "11111111111111111111111111111111" }
      ],
      "args": [
        { "name": "deadline_seconds", "type": "i64" }
      ]
    },
    {
      "name": "ping",
      "accounts": [
        { "name": "switch", "writable": true, "pda": { "seeds": [{ "kind": "const", "value": [115,119,105,116,99,104] }, { "kind": "account", "path": "owner" }] } },
        { "name": "owner",  "signer": true }
      ],
      "args": []
    },
    {
      "name": "check_status",
      "accounts": [
        { "name": "switch", "writable": true, "pda": { "seeds": [{ "kind": "const", "value": [115,119,105,116,99,104] }, { "kind": "account", "path": "switch", "field": "owner" }] } }
      ],
      "args": []
    }
  ],
  "accounts": [
    {
      "name": "SwitchState",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "owner",            "type": "pubkey" },
          { "name": "last_heartbeat",   "type": "i64"    },
          { "name": "deadline_seconds", "type": "i64"    },
          { "name": "is_dead",          "type": "bool"   }
        ]
      }
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "AlreadyDead",
      "msg": "This switch has already been triggered — the owner is considered dead"
    }
  ]
}
